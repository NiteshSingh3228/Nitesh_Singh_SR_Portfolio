# Copy this file to .env.local and fill in your details

# Gmail SMTP Configuration for Contact Form
# 1. Go to your Google Account > Security
# 2. Enable 2-Step Verification
# 3. Create an "App Password" (Search for "App passwords" in settings)
# 4. Use your email and the generated app password below

SMTP_EMAIL="your_email@gmail.com"
SMTP_PASSWORD="your_app_password_here"
